# App
APP_NAME=gateway-service
APP_ENV=development
APP_PORT=8000
DEBUG=true

# JWT
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# PostgreSQL
POSTGRES_HOST=postgres-gateway
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=admin
POSTGRES_DB=agentica_gateway
# DATABASE_URL=postgresql+asyncpg://postgres:admin@postgres-gateway:5432/agentica_gateway

# Redis
REDIS_HOST=redis-gateway
REDIS_PORT=6379
REDIS_DB=0

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# Upstream Services
RAG_SERVICE_URL=http://rag-service-svc:8001
LLM_SERVICE_URL=http://llm-service-svc:8002
MEMORY_SERVICE_URL=http://memory-service-svc:8003
AGENT_SERVICE_URL=http://agent-service-svc:8004

# Logging
LOG_LEVEL=INFO