# App
APP_NAME=llm-service
APP_ENV=development
APP_PORT=8002
DEBUG=true

# Ollama
OLLAMA_HOST=localhost
OLLAMA_PORT=11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_TIMEOUT=120

# Generation
MAX_TOKENS=1024
TEMPERATURE=0.7
TOP_P=0.9
STREAM=true

# RAG Service
RAG_SERVICE_URL=http://localhost:8001

# Logging
LOG_LEVEL=INFO
