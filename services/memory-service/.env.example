# App
APP_NAME=memory-service
APP_ENV=development
APP_PORT=8003
DEBUG=true

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=admin
POSTGRES_DB=agentica_memory
DATABASE_URL=postgresql+asyncpg://postgres:admin@localhost:5432/agentica_memory

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_TTL=3600

# Memory
MAX_HISTORY_MESSAGES=20
SESSION_TTL_HOURS=24

# Logging
LOG_LEVEL=INFO