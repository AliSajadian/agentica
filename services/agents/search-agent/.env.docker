# App
APP_NAME=search-agent
APP_ENV=development
APP_PORT=8012
DEBUG=true

# Search
SEARCH_PROVIDER="tavily"

# Shared
TIMEOUT=30

# Tavily Search API
TAVILY_BASE_URL=https://api.tavily.com

# Brave Search API
BRAVE_BASE_URL=https://api.search.brave.com/res/v1
BRAVE_SAFESEARCH=moderate
BRAVE_COUNT=10

# DuckDuckGo Search API 
DUCKDUCKGO_BASE_URL=https://api.duckduckgo.com

# Redis Cache
REDIS_HOST=redis-search
REDIS_PORT=6379
REDIS_DB=3
SEARCH_CACHE_TTL=300

# Logging
LOG_LEVEL=INFO